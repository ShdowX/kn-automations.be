---
import Base from './Base.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
  lang?: 'en' | 'nl';
}

const { post, lang = 'en' } = Astro.props;

const pubDateFormatted = post.data.date.toISOString().split('T')[0];
const siteUrl = Astro.site ? new URL(Astro.site) : new URL('https://kn-automations.be');
const authorUrl = siteUrl.toString();
const articleUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL('/og-image.jpg', siteUrl).toString();
const wordCountEstimate = Number.parseInt(post.data.readTime, 10);

// Generate schema markup for this blog post
const blogPostSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  'headline': post.data.title,
  'description': post.data.excerpt,
  'image': ogImageUrl,
  'url': articleUrl,
  'mainEntityOfPage': articleUrl,
  'datePublished': pubDateFormatted,
  'dateModified': pubDateFormatted,
  'author': {
    '@type': 'Person',
    'name': 'Kenneth Nicasens',
    'url': authorUrl,
  },
  'publisher': {
    '@type': 'Organization',
    'name': 'Kenneth Nicasens',
    'url': authorUrl,
    'logo': {
      '@type': 'ImageObject',
      'url': new URL('/images/about-portrait.svg', siteUrl).toString(),
    },
  },
  'isPartOf': {
    '@type': 'Blog',
    'name': 'Kenneth Nicasens',
    'url': siteUrl.toString(),
  },
  'keywords': [post.data.category],
  'articleSection': post.data.category,
  'wordCount': Number.isNaN(wordCountEstimate) ? undefined : wordCountEstimate * 220,
  'isAccessibleForFree': true,
  'inLanguage': lang === 'nl' ? 'nl-BE' : 'en-GB',
};
---

<Base
  title={post.data.title}
  description={post.data.excerpt}
  lang={lang}
>
  <script type="application/ld+json" set:html={JSON.stringify(blogPostSchema)} />
  <slot />
</Base>
