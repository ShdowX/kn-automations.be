---
interface Props {
  lang?: 'en' | 'nl';
}

const { lang = 'en' } = Astro.props;

const copy = {
  en: {
    label: 'Email address',
    placeholder: 'your@email.com',
    button: 'Subscribe',
    loading: 'Subscribing...',
    success: 'Thanks! Check your inbox to confirm.',
    error: 'Something went wrong. Try again?',
  },
  nl: {
    label: 'E-mailadres',
    placeholder: 'jouw@email.com',
    button: 'Inschrijven',
    loading: 'Wordt ingeschreven...',
    success: 'Bedankt! Controleer je inbox ter bevestiging.',
    error: 'Er ging iets mis. Probeer opnieuw?',
  },
};

const t = copy[lang];
---

<form class="subscribe-form" data-lang={lang}>
  <div class="subscribe-group">
    <label for={`email-${lang}`} class="subscribe-label">{t.label}</label>
    <div class="subscribe-input-wrapper">
      <input
        id={`email-${lang}`}
        type="email"
        name="email"
        placeholder={t.placeholder}
        required
        class="subscribe-input"
      />
      <button type="submit" class="subscribe-button">
        <span class="button-text">{t.button}</span>
        <span class="button-arrow">→</span>
      </button>
    </div>
  </div>
  <div class="subscribe-message"></div>
</form>

<script>
  const forms = document.querySelectorAll('.subscribe-form');

  forms.forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const email = (form.querySelector('input[name="email"]') as HTMLInputElement).value;
      const lang = form.getAttribute('data-lang') || 'en';

      // Basic email validation
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailRegex.test(email)) {
        showMessage(form, lang, 'error');
        return;
      }

      const button = form.querySelector('.subscribe-button') as HTMLButtonElement;
      const buttonText = form.querySelector('.button-text') as HTMLElement;
      const originalText = buttonText.textContent;
      const loadingText = lang === 'nl' ? 'Wordt ingeschreven...' : 'Subscribing...';

      // Disable button and show loading state
      button.disabled = true;
      buttonText.textContent = loadingText;

      try {
        // Formspree will auto-create the form using the email endpoint
        const email = 'kenneth.nicasens@gmail.com';
        const response = await fetch(`https://formspree.io/f/mdablvgq`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Accept: 'application/json',
          },
          body: JSON.stringify({ 
            email, 
            lang,
            _subject: `New newsletter signup - ${lang === 'nl' ? 'Nederlands' : 'English'}`
          }),
        });

        if (response.ok) {
          showMessage(form, lang, 'success');
          (form.querySelector('input[name="email"]') as HTMLInputElement).value = '';
          button.disabled = false;
          buttonText.textContent = originalText;
        } else {
          showMessage(form, lang, 'error');
          button.disabled = false;
          buttonText.textContent = originalText;
        }
      } catch (error) {
        showMessage(form, lang, 'error');
        button.disabled = false;
        buttonText.textContent = originalText;
      }
    });
  });

  function showMessage(form: Element, lang: string, type: 'success' | 'error') {
    const messageEl = form.querySelector('.subscribe-message') as HTMLElement;
    const messages = {
      en: {
        success: 'Thanks! Check your inbox to confirm.',
        error: 'Something went wrong. Try again?',
      },
      nl: {
        success: 'Bedankt! Controleer je inbox ter bevestiging.',
        error: 'Er ging iets mis. Probeer opnieuw?',
      },
    };

    messageEl.textContent = messages[lang as keyof typeof messages][type];
    messageEl.className = `subscribe-message subscribe-message-${type}`;

    // Clear message after 4 seconds
    setTimeout(() => {
      messageEl.textContent = '';
      messageEl.className = 'subscribe-message';
    }, 4000);
  }
</script>
